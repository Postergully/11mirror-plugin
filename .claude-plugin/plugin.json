{
  "name": "11mirror",
  "version": "0.26.6-fbrain.1",
  "description": "11Mirror enterprise knowledge layer — fbrain + Cognee behind a unified MCP gateway.",
  "author": {
    "name": "11Mirror"
  },
  "mcpServers": {
    "11mirror": {
      "type": "stdio",
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/bin/mcp-stdio-bridge.js"],
      "env": {
        "GATEWAY_URL": "${gateway_url}",
        "GATEWAY_API_KEY": "${gateway_api_key}"
      }
    }
  }
}
