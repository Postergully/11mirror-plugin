{
  "name": "11mirror",
  "version": "0.26.6-fbrain.1",
  "description": "11Mirror enterprise knowledge layer — fbrain + Cognee behind a unified MCP gateway.",
  "family": "bundle-plugin",
  "configSchema": {
    "gateway_url": {
      "type": "string",
      "required": true,
      "description": "HTTPS URL of the 11Mirror gateway /mcp endpoint (e.g., https://connect.neuu.in/mcp)"
    },
    "gateway_api_key": {
      "type": "string",
      "required": true,
      "description": "Bearer token for the gateway",
      "uiHints": {
        "sensitive": true
      }
    }
  },
  "mcpServers": {
    "11mirror": {
      "type": "http",
      "url": "${gateway_url}",
      "headers": {
        "Authorization": "Bearer ${gateway_api_key}"
      }
    }
  },
  "skills": [
    "skills/11mirror-graph-reasoning",
    "skills/academic-verify",
    "skills/archive-crawler",
    "skills/article-enrichment",
    "skills/book-mirror",
    "skills/brain-ops",
    "skills/brain-pdf",
    "skills/briefing",
    "skills/citation-fixer",
    "skills/concept-synthesis",
    "skills/cross-modal-review",
    "skills/cron-scheduler",
    "skills/daily-task-manager",
    "skills/daily-task-prep",
    "skills/data-research",
    "skills/enrich",
    "skills/frontmatter-guard",
    "skills/idea-ingest",
    "skills/ingest",
    "skills/install",
    "skills/maintain",
    "skills/media-ingest",
    "skills/meeting-ingestion",
    "skills/minion-orchestrator",
    "skills/perplexity-research",
    "skills/query",
    "skills/reports",
    "skills/repo-architecture",
    "skills/signal-detector",
    "skills/skill-creator",
    "skills/skillify",
    "skills/skillpack-check",
    "skills/smoke-test",
    "skills/soul-audit",
    "skills/strategic-reading",
    "skills/testing",
    "skills/voice-note-ingest",
    "skills/webhook-transforms"
  ],
  "shared_deps": [
    "skills/conventions",
    "skills/_brain-filing-rules.md",
    "skills/_brain-filing-rules.json",
    "skills/_friction-protocol.md",
    "skills/_output-rules.md"
  ],
  "excluded_from_install": [
    "skills/setup",
    "skills/migrate",
    "skills/publish"
  ],
  "openclaw": {
    "compat": {
      "pluginApi": ">=2026.4.0"
    }
  }
}
